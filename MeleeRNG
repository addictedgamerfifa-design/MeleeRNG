-- Stats update loop
task.spawn(function()
    local lastKills = 0
    local lastTime = os.clock()
    while true do
        task.wait(1)
        pcall(function()
            local kills = tonumber(getCachedStat("Kills")) or 0
            local mana = tonumber(getCachedStat("Mana")) or 0
            local sp = tonumber(getCachedStat("SP")) or 0
            local ascends = tonumber(getCachedStat("Ascends")) or 0
            local required = (2 + ascends) * 1000000
            local remaining = math.max(0, required - kills)
            local now = os.clock()
            local elapsed = now - lastTime
            local killsGained = kills - lastKills
            local kpm = elapsed > 0 and (killsGained / elapsed) * 60 or 0
            lastKills = kills
            lastTime = now
            local etaStr = "unknown"
            if kpm > 0 then
                local etaMins = remaining / kpm
                if etaMins < 60 then
                    etaStr = string.format("%.0fm %.0fs", math.floor(etaMins), math.floor((etaMins % 1) * 60))
                else
                    etaStr = string.format("%.0fh %.0fm", math.floor(etaMins / 60), math.floor(etaMins % 60))
                end
            end
            local areaName = "Unknown"
            pcall(function()
                local area = invokeR("GetArea")
                if area and area.Name then areaName = area.Name end
            end)
            local line1 = string.format("Kills: %s | Mana: %s | SP: %s | Ascends: %d",
                tostring(math.floor(kills)), tostring(math.floor(mana)), tostring(math.floor(sp)), ascends)
            local line2 = string.format("KPM: %.1f | ETA -> %s: %s", kpm, areaName, etaStr)
            local line3 = string.format("Ascend: %s / %s (%s more)",
                tostring(math.floor(kills)), tostring(required), tostring(remaining))
            local line4 = string.format("Aura: %s", selectedAura or "none")
            local fullText = line1 .. "\n" .. line2 .. "\n" .. line3 .. "\n" .. line4
            if statsLabel and statsLabel.Set then
                pcall(function() statsLabel.Set(fullText) end)
            end
            if hudEnabled and hudLabel and hudLabel.Parent then
                hudLabel.Text = fullText
            end
        end)
    end
end)

