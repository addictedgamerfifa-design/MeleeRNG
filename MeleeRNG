MiscTab:CreateSection("Value Spoofs")

MiscTab:CreateToggle({
    Name = "Damage Multiplier x5",
    CurrentValue = false,
    Flag = "DmgSpoof",
    Callback = function(on)
        if on then
            local oldNamecall
            oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
                local method = getnamecallmethod()
                if method == "InvokeServer" and self.Name == "GetUpgradeValue" then
                    local args = {...}
                    local result = oldNamecall(self, ...)
                    if args[1] == "Damage Multiplier" then return result * 5 end
                    return result
                end
                return oldNamecall(self, ...)
            end)
            Rayfield:Notify({Title = "Spoof ON", Content = "Damage x5", Duration = 3})
        end
    end
})

