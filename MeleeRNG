local function buildAreaButtons()
    -- Clear existing tab content by rebuilding
    AreaTab:CreateSection("Areas")

    local areasFolder = workspace:FindFirstChild("Areas")
    if areasFolder then
        local areas = areasFolder:GetChildren()
        table.sort(areas, function(a, b)
            local ak = tonumber(a:GetAttribute("MinimumKills")) or 0
            local bk = tonumber(b:GetAttribute("MinimumKills")) or 0
            return ak < bk
        end)

        local kills = tonumber(getCachedStat("Kills")) or 0
        local unlocked = 0

        for _, area in ipairs(areas) do
            local areaRef = area
            local minKills = tonumber(area:GetAttribute("MinimumKills")) or 0
            local areaName = area.Name
            local meetsReq = kills >= minKills
            if meetsReq then unlocked = unlocked + 1 end

            local buttonName = meetsReq
                and "✅ " .. areaName .. " (" .. tostring(minKills) .. " kills)"
                or "⬜ " .. areaName .. " (" .. tostring(minKills) .. " kills)"

            AreaTab:CreateButton({
                Name = buttonName,
                Callback = function()
                    local root = getRoot()
                    if not root then
                        Rayfield:Notify({Title = "Error", Content = "No character found", Duration = 3})
                        return
                    end
                    local sp = areaRef:FindFirstChild("SpawnPoint")
                    if sp then
                        root.CFrame = sp.CFrame + Vector3.new(0, 5, 0)
                    else
                        local bb = areaRef:FindFirstChildOfClass("BasePart")
                        if bb then
                            root.CFrame = CFrame.new(bb.Position + Vector3.new(0, 5, 0))
                        end
                    end
                    Rayfield:Notify({
                        Title = "Teleported",
                        Content = "Went to " .. areaName .. " | Req: " .. tostring(minKills) .. " kills",
                        Duration = 3
                    })
                end
            })
        end

        Rayfield:Notify({
            Title = "Areas Refreshed",
            Content = string.format("%d/%d unlocked | Kills: %s", unlocked, #areas, tostring(math.floor(kills))),
            Duration = 4
        })
    else
        AreaTab:CreateButton({
            Name = "No areas found — try rejoining",
            Callback = function() end
        })
    end
end

