local upgradeLevelCap = {}
local upgradeStatusLabel = nil

local function getUpgradeStatusText()
    local sp = tonumber(getCachedStat("SP")) or 0
    local lines = {"SP: " .. tostring(math.floor(sp)), ""}
    for _, name in ipairs(UPGRADE_ORDER) do
        if upgradeSelected[name] then
            local lvl = invokeR("GetUpgradeLevel", name) or 0
            local cap = upgradeLevelCap[name]
            local atCap = cap and lvl >= cap
            local priceFn = UPGRADE_PRICES[name]
            local price = nil
            if priceFn then
                local ok, p = pcall(priceFn, lvl + 1)
                if ok then price = math.floor(p) end
            end
            local capStr = cap and (" | cap: " .. tostring(cap)) or ""
            if atCap then
                lines[#lines + 1] = name .. ": Lv" .. tostring(lvl) .. " AT CAP" .. capStr
            elseif price then
                -- Estimate time based on SP gain rate
                local etaStr = ""
                if price > sp then
                    lines[#lines + 1] = name .. ": Lv" .. tostring(lvl) .. " | next: " .. tostring(price) .. " SP" .. capStr
                else
                    lines[#lines + 1] = name .. ": Lv" .. tostring(lvl) .. " | READY (" .. tostring(price) .. " SP)" .. capStr
                end
            else
                lines[#lines + 1] = name .. ": Lv" .. tostring(lvl) .. capStr
            end
        end
    end
    if #lines == 2 then
        return "No upgrades selected"
    end
    return table.concat(lines, "\n")
end

